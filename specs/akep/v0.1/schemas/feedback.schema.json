{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feedback.schema.json",
  "title": "AKEP v0.1 feedback request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "akepVersion",
    "feedbackId",
    "usageId",
    "citations",
    "taskCategory",
    "outcome",
    "evaluatorVersion",
    "observedAt",
    "critical"
  ],
  "properties": {
    "akepVersion": { "const": "0.1" },
    "feedbackId": { "$ref": "common.schema.json#/$defs/uri" },
    "usageId": { "$ref": "common.schema.json#/$defs/uri" },
    "citations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["citationId", "revisionId", "payloadDigest", "locator"],
        "properties": {
          "citationId": { "$ref": "common.schema.json#/$defs/uri" },
          "revisionId": {
            "$ref": "common.schema.json#/$defs/revisionId"
          },
          "payloadDigest": { "$ref": "common.schema.json#/$defs/digest" },
          "locator": { "$ref": "query-result.schema.json#/$defs/locator" },
          "outcome": {
            "enum": ["helped", "neutral", "harmed", "unknown"]
          }
        }
      }
    },
    "taskCategory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "outcome": {
      "enum": ["helped", "neutral", "harmed", "unknown"]
    },
    "metrics": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._:-]{0,127}$"
          },
          "value": { "type": "number" },
          "unit": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        }
      }
    },
    "evaluatorVersion": { "$ref": "common.schema.json#/$defs/schemaRef" },
    "contextDigest": { "$ref": "common.schema.json#/$defs/digest" },
    "evidenceRefs": {
      "type": "array",
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "observedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rawTaskStored": { "type": "boolean" },
        "aggregation": {
          "enum": ["none", "pseudonymized", "aggregated"]
        },
        "retentionUntil": {
          "$ref": "common.schema.json#/$defs/timestamp"
        }
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    },
    "critical": {
      "$ref": "common.schema.json#/$defs/critical"
    }
  }
}
