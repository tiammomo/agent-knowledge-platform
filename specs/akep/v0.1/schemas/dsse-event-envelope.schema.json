{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dsse-event-envelope.schema.json",
  "title": "AKEP v0.1 DSSE federation event envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["payloadType", "payload", "signatures"],
  "properties": {
    "payloadType": { "const": "application/cloudevents+json" },
    "payload": {
      "description": "Base64 of JCS bytes that validate against federation-event.schema.json.",
      "type": "string",
      "contentEncoding": "base64"
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyid", "sig"],
        "properties": {
          "keyid": { "type": "string", "minLength": 1, "maxLength": 2048 },
          "sig": { "type": "string", "contentEncoding": "base64" }
        }
      }
    }
  }
}
