{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery-ack.schema.json",
  "title": "AKEP v0.1 federation delivery acknowledgement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "akepVersion",
    "ackId",
    "deliveryId",
    "checkpoint",
    "eventSetDigest",
    "status",
    "policyEpoch",
    "appliedAt",
    "critical"
  ],
  "properties": {
    "akepVersion": { "const": "0.1" },
    "ackId": { "$ref": "common.schema.json#/$defs/uri" },
    "deliveryId": { "$ref": "common.schema.json#/$defs/uri" },
    "checkpoint": { "$ref": "signed-checkpoint.schema.json" },
    "eventSetDigest": { "$ref": "common.schema.json#/$defs/digest" },
    "eventIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 255 }
    },
    "status": { "enum": ["applied", "rejected"] },
    "problemRefs": {
      "type": "array",
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "policyEpoch": { "type": "string", "minLength": 1, "maxLength": 255 },
    "appliedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "rejected" } },
        "required": ["status"]
      },
      "then": {
        "required": ["problemRefs"],
        "properties": {
          "problemRefs": { "type": "array", "minItems": 1 }
        }
      }
    }
  ]
}
