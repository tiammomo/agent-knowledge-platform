{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decision.schema.json",
  "title": "AKEP v0.1 curator decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "akepVersion",
    "decisionId",
    "decision",
    "rationale",
    "policyVersion",
    "attestationRefs",
    "critical"
  ],
  "properties": {
    "akepVersion": { "const": "0.1" },
    "decisionId": { "$ref": "common.schema.json#/$defs/uri" },
    "decision": {
      "enum": ["verify", "reject", "request_evidence", "quarantine"]
    },
    "rationale": { "type": "string", "minLength": 1, "maxLength": 10000 },
    "policyVersion": { "$ref": "common.schema.json#/$defs/schemaRef" },
    "attestationRefs": {
      "type": "array",
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": { "const": "verify" }
        },
        "required": ["decision"]
      },
      "then": {
        "properties": {
          "attestationRefs": { "type": "array" }
        }
      }
    }
  ]
}
