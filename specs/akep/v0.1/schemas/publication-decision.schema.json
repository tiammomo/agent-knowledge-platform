{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "publication-decision.schema.json",
  "title": "AKEP v0.1 publication or safety action decision body",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "akepVersion",
    "decisionId",
    "rationale",
    "policyVersion",
    "expectedPolicyEpoch",
    "attestationRefs",
    "critical"
  ],
  "properties": {
    "akepVersion": { "const": "0.1" },
    "decisionId": { "$ref": "common.schema.json#/$defs/uri" },
    "rationale": { "type": "string", "minLength": 1, "maxLength": 10000 },
    "policyVersion": { "$ref": "common.schema.json#/$defs/schemaRef" },
    "expectedPolicyEpoch": { "type": "string", "minLength": 1, "maxLength": 255 },
    "attestationRefs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  }
}
