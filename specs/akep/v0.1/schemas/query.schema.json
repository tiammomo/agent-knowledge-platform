{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query.schema.json",
  "title": "AKEP v0.1 query request",
  "type": "object",
  "additionalProperties": false,
  "required": ["query", "mode", "purpose", "supportedObligations", "limit", "critical"],
  "properties": {
    "query": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "maxLength": 32000
            },
            "locale": {
              "type": "string",
              "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reference"],
          "properties": {
            "reference": {
              "$ref": "common.schema.json#/$defs/revisionId"
            }
          }
        }
      ]
    },
    "mode": {
      "enum": ["lexical", "semantic", "hybrid", "exact"]
    },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assetTypes": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "enum": [
              "source_document",
              "assertion",
              "observation",
              "procedure",
              "policy",
              "example",
              "failure_case",
              "hypothesis",
              "dataset",
              "prompt",
              "capability_manifest"
            ]
          }
        },
        "profiles": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "$ref": "common.schema.json#/$defs/uri" }
        },
        "labels": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "validAt": { "$ref": "common.schema.json#/$defs/timestamp" },
        "channels": {
          "type": "array",
          "maxItems": 10,
          "uniqueItems": true,
          "items": {
            "enum": ["published", "verified"]
          }
        },
        "includeDeprecated": { "type": "boolean", "default": false }
      }
    },
    "purpose": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._:-]{0,127}$"
    },
    "supportedObligations": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/obligation" }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "cursor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192
    },
    "minCheckpoint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192
    },
    "include": {
      "type": "array",
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "enum": [
          "summary",
          "passages",
          "relations",
          "attestations",
          "provenance"
        ]
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    },
    "critical": {
      "$ref": "common.schema.json#/$defs/critical"
    }
  }
}
