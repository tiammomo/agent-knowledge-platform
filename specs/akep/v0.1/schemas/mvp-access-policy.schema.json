{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mvp-access-policy.schema.json",
  "title": "AKEP Phase 1 fixed access policy profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyProfile",
    "policyId",
    "tenantId",
    "defaultEffect",
    "combiningAlgorithm",
    "rules",
    "issuedBy",
    "issuedAt",
    "critical"
  ],
  "properties": {
    "policyProfile": { "const": "https://agentknowledge.dev/policy-profiles/mvp-access/1" },
    "policyId": { "$ref": "common.schema.json#/$defs/uri" },
    "tenantId": { "$ref": "common.schema.json#/$defs/uri" },
    "defaultEffect": { "const": "deny" },
    "combiningAlgorithm": { "const": "deny-overrides" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ruleId", "effect", "subjectSets", "spaces",
          "classifications", "purposes", "obligations"
        ],
        "properties": {
          "ruleId": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" },
          "effect": { "enum": ["allow", "deny"] },
          "subjectSets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "uniqueItems": true,
            "items": { "$ref": "common.schema.json#/$defs/uri" }
          },
          "spaces": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "uniqueItems": true,
            "items": { "$ref": "common.schema.json#/$defs/uri" }
          },
          "classifications": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": { "enum": ["public", "internal", "confidential"] }
          },
          "purposes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" }
          },
          "obligations": {
            "type": "array",
            "maxItems": 100,
            "uniqueItems": true,
            "items": { "$ref": "common.schema.json#/$defs/obligation" }
          }
        }
      }
    },
    "issuedBy": { "$ref": "common.schema.json#/$defs/uri" },
    "issuedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  }
}
