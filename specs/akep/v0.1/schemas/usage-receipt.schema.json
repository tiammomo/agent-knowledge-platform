{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "usage-receipt.schema.json",
  "title": "AKEP v0.1 usage receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "usageId",
    "exposureReceiptId",
    "spaceId",
    "citations",
    "policyDecisionId",
    "policyEpoch",
    "createdAt",
    "feedbackUntil"
  ],
  "properties": {
    "usageId": { "$ref": "common.schema.json#/$defs/uri" },
    "exposureReceiptId": { "$ref": "common.schema.json#/$defs/uri" },
    "spaceId": { "$ref": "common.schema.json#/$defs/uri" },
    "citations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "usage.schema.json#/$defs/usedCitation" }
    },
    "policyDecisionId": { "$ref": "common.schema.json#/$defs/uri" },
    "policyEpoch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "createdAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "feedbackUntil": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
