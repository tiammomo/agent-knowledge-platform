{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset-manifest.schema.json",
  "title": "AKEP v0.1 asset manifest",
  "description": "Canonical immutable manifest. revisionId, mutable channels, proofs and locations are deliberately excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "recordId",
    "profile",
    "assetType",
    "title",
    "payloads",
    "provenance",
    "policy",
    "critical"
  ],
  "properties": {
    "manifestVersion": { "const": "0.1" },
    "recordId": {
      "$ref": "common.schema.json#/$defs/uri"
    },
    "profile": {
      "$ref": "common.schema.json#/$defs/schemaRef"
    },
    "schema": {
      "$ref": "common.schema.json#/$defs/schemaRef"
    },
    "parents": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "$ref": "common.schema.json#/$defs/revisionId"
      }
    },
    "assetType": {
      "enum": [
        "source_document",
        "assertion",
        "observation",
        "procedure",
        "policy",
        "example",
        "failure_case",
        "hypothesis",
        "dataset",
        "prompt",
        "capability_manifest"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "summary": {
      "type": "string",
      "maxLength": 5000
    },
    "payloads": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "common.schema.json#/$defs/payloadDescriptor"
      },
      "contains": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "const": "primary" }
        }
      },
      "minContains": 1,
      "maxContains": 1
    },
    "scope": {
      "$ref": "common.schema.json#/$defs/scope"
    },
    "provenance": {
      "$ref": "common.schema.json#/$defs/provenance"
    },
    "policy": {
      "$ref": "common.schema.json#/$defs/policy"
    },
    "relations": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "$ref": "common.schema.json#/$defs/relation"
      }
    },
    "labels": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    },
    "critical": {
      "$ref": "common.schema.json#/$defs/critical"
    }
  }
}
