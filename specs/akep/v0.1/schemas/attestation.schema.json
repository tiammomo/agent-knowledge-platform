{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "attestation.schema.json",
  "title": "AKEP v0.1 attestation statement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attestationVersion",
    "attestationId",
    "type",
    "subject",
    "issuer",
    "issuedAt",
    "expiresAt",
    "method",
    "result",
    "evidenceRefs",
    "critical"
  ],
  "properties": {
    "attestationVersion": { "const": "0.1" },
    "attestationId": { "$ref": "common.schema.json#/$defs/uri" },
    "type": {
      "oneOf": [
        {
          "enum": [
            "authorship",
            "schema-validation",
            "provenance-validation",
            "human-review",
            "benchmark-result",
            "safety-scan",
            "license-review",
            "policy-approval",
            "signature-verification"
          ]
        },
        { "$ref": "common.schema.json#/$defs/uri" }
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revisionId"],
      "properties": {
        "revisionId": { "$ref": "common.schema.json#/$defs/revisionId" },
        "payloadDigest": { "$ref": "common.schema.json#/$defs/digest" }
      }
    },
    "issuer": { "$ref": "common.schema.json#/$defs/uri" },
    "issuedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "expiresAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "method": { "$ref": "common.schema.json#/$defs/schemaRef" },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome"],
      "properties": {
        "outcome": { "enum": ["pass", "fail", "warning", "informational"] },
        "summary": { "type": "string", "maxLength": 5000 },
        "findings": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "severity"],
            "properties": {
              "code": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$"
              },
              "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
              "message": { "type": "string", "maxLength": 5000 }
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "maxProperties": 100
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "envelopeRef": { "$ref": "common.schema.json#/$defs/uri" },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  }
}
