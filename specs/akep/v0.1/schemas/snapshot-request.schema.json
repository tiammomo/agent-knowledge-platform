{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "snapshot-request.schema.json",
  "title": "AKEP v0.1 federation snapshot request",
  "type": "object",
  "additionalProperties": false,
  "required": ["akepVersion", "spaces", "purpose", "sharingMode", "critical"],
  "properties": {
    "akepVersion": { "const": "0.1" },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "profiles": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "assetTypes": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "enum": [
          "source_document",
          "assertion",
          "observation",
          "procedure",
          "policy",
          "example",
          "failure_case",
          "hypothesis",
          "dataset",
          "prompt",
          "capability_manifest"
        ]
      }
    },
    "purpose": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._:-]{0,127}$"
    },
    "sharingMode": { "enum": ["metadata_only", "reference_only", "copy"] },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  }
}
