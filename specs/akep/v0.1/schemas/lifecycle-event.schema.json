{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lifecycle-event.schema.json",
  "title": "AKEP v0.1 lifecycle event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventVersion",
    "eventId",
    "eventType",
    "spaceId",
    "trustDomain",
    "recordId",
    "revisionId",
    "actor",
    "policyVersion",
    "policyEpoch",
    "reason",
    "occurredAt",
    "critical"
  ],
  "properties": {
    "eventVersion": { "const": "0.1" },
    "eventId": { "$ref": "common.schema.json#/$defs/uri" },
    "eventType": { "enum": ["channel.updated", "status.asserted", "status.cleared"] },
    "spaceId": { "$ref": "common.schema.json#/$defs/uri" },
    "trustDomain": { "type": "string", "minLength": 1, "maxLength": 255 },
    "recordId": { "$ref": "common.schema.json#/$defs/uri" },
    "revisionId": { "$ref": "common.schema.json#/$defs/revisionId" },
    "channel": { "enum": ["candidate", "verified", "published"] },
    "status": { "enum": ["deprecated", "revoked", "quarantined", "erased"] },
    "actor": { "$ref": "common.schema.json#/$defs/uri" },
    "policyVersion": { "$ref": "common.schema.json#/$defs/schemaRef" },
    "policyEpoch": { "type": "string", "minLength": 1, "maxLength": 255 },
    "reason": { "type": "string", "minLength": 1, "maxLength": 10000 },
    "occurredAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "previousEventId": { "$ref": "common.schema.json#/$defs/uri" },
    "attestationRefs": {
      "type": "array",
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "eventType": { "const": "channel.updated" } },
        "required": ["eventType"]
      },
      "then": {
        "required": ["channel"],
        "properties": {
          "channel": {},
          "status": false
        }
      }
    },
    {
      "if": {
        "properties": { "eventType": { "enum": ["status.asserted", "status.cleared"] } },
        "required": ["eventType"]
      },
      "then": {
        "required": ["status"],
        "properties": {
          "channel": false,
          "status": {}
        }
      }
    },
    {
      "if": {
        "properties": { "eventType": { "const": "status.cleared" } },
        "required": ["eventType"]
      },
      "then": {
        "properties": {
          "status": { "enum": ["deprecated", "quarantined"] }
        }
      }
    }
  ]
}
