{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "authorization-plan.schema.json",
  "title": "AKEP Phase 1 internal authorization plan contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "decisionId", "subjectDigest", "tenantId", "spaces",
    "purpose", "policyEpoch", "allowedVisibilityPartitions",
    "backendPredicateHandle", "backendPredicateDigest", "obligations",
    "issuedAt", "expiresAt"
  ],
  "properties": {
    "planVersion": { "const": "0.1" },
    "decisionId": { "$ref": "common.schema.json#/$defs/uri" },
    "subjectDigest": { "$ref": "common.schema.json#/$defs/digest" },
    "tenantId": { "$ref": "common.schema.json#/$defs/uri" },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/uri" }
    },
    "purpose": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" },
    "policyEpoch": { "type": "string", "minLength": 1, "maxLength": 255 },
    "allowedVisibilityPartitions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 255 }
    },
    "backendPredicateHandle": {
      "type": "string",
      "minLength": 16,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9._~:-]+$",
      "description": "Opaque server-local handle for a stored, parameterized predicate; never executable SQL or caller input."
    },
    "backendPredicateDigest": { "$ref": "common.schema.json#/$defs/digest" },
    "obligations": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/obligation" }
    },
    "issuedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "expiresAt": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
