{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "usage.schema.json",
  "title": "AKEP v0.1 usage request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "akepVersion",
    "clientUsageId",
    "exposureReceiptId",
    "spaceId",
    "citations",
    "taskCategory",
    "purpose",
    "occurredAt",
    "critical"
  ],
  "properties": {
    "akepVersion": { "const": "0.1" },
    "clientUsageId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "exposureReceiptId": { "$ref": "common.schema.json#/$defs/uri" },
    "spaceId": { "$ref": "common.schema.json#/$defs/uri" },
    "citations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/usedCitation" }
    },
    "taskCategory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "purpose": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._:-]{0,127}$"
    },
    "contextDigest": { "$ref": "common.schema.json#/$defs/digest" },
    "occurredAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  },
  "$defs": {
    "usedCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citationId",
        "revisionId",
        "payloadDigest",
        "locator",
        "influence"
      ],
      "properties": {
        "citationId": { "$ref": "common.schema.json#/$defs/uri" },
        "revisionId": { "$ref": "common.schema.json#/$defs/revisionId" },
        "payloadDigest": { "$ref": "common.schema.json#/$defs/digest" },
        "locator": { "$ref": "query-result.schema.json#/$defs/locator" },
        "influence": { "enum": ["primary", "supporting", "seen"] }
      }
    }
  }
}
