{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "federation-event.schema.json",
  "title": "AKEP v0.1 canonical federation CloudEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "akepstreamid",
    "akepepoch",
    "akepsequence",
    "akeporigintrustdomain",
    "akepissuer",
    "akepaudience",
    "akepexpires",
    "data"
  ],
  "properties": {
    "specversion": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1, "maxLength": 255 },
    "source": { "$ref": "common.schema.json#/$defs/uri" },
    "type": {
      "enum": [
        "org.akep.revision.accepted.v1",
        "org.akep.channel.updated.v1",
        "org.akep.attestation.issued.v1",
        "org.akep.revision.revoked.v1",
        "org.akep.revision.erase-requested.v1"
      ]
    },
    "subject": { "$ref": "common.schema.json#/$defs/uri" },
    "time": { "$ref": "common.schema.json#/$defs/timestamp" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": { "$ref": "common.schema.json#/$defs/uri" },
    "akepstreamid": { "type": "string", "minLength": 1, "maxLength": 255 },
    "akepepoch": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "akepsequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "akeppreviouseventhash": { "$ref": "common.schema.json#/$defs/digest" },
    "akeporigintrustdomain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "akepissuer": { "$ref": "common.schema.json#/$defs/uri" },
    "akepaudience": { "$ref": "common.schema.json#/$defs/uri" },
    "akepexpires": { "$ref": "common.schema.json#/$defs/timestamp" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spaceId", "recordId", "revisionId", "critical"],
      "properties": {
        "spaceId": { "$ref": "common.schema.json#/$defs/uri" },
        "recordId": { "$ref": "common.schema.json#/$defs/uri" },
        "revisionId": { "$ref": "common.schema.json#/$defs/revisionId" },
        "manifest": { "$ref": "asset-manifest.schema.json" },
        "lifecycleEvent": { "$ref": "lifecycle-event.schema.json" },
        "attestation": { "$ref": "attestation.schema.json" },
        "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
        "critical": { "$ref": "common.schema.json#/$defs/critical" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "akepsequence": { "type": "integer", "minimum": 1 } },
        "required": ["akepsequence"]
      },
      "then": {
        "required": ["akeppreviouseventhash"],
        "properties": { "akeppreviouseventhash": {} }
      },
      "else": {
        "properties": { "akeppreviouseventhash": false }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "org.akep.revision.accepted.v1" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["manifest"],
            "properties": {
              "manifest": {},
              "lifecycleEvent": false,
              "attestation": false
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "org.akep.channel.updated.v1",
              "org.akep.revision.revoked.v1",
              "org.akep.revision.erase-requested.v1"
            ]
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["lifecycleEvent"],
            "properties": {
              "manifest": false,
              "lifecycleEvent": {},
              "attestation": false
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "org.akep.attestation.issued.v1" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["attestation"],
            "properties": {
              "manifest": false,
              "lifecycleEvent": false,
              "attestation": {}
            }
          }
        }
      }
    }
  ]
}
