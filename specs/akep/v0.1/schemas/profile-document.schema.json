{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "profile-document.schema.json",
  "title": "AKEP v0.1 immutable knowledge profile document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profileVersion",
    "profileId",
    "assetType",
    "primaryPayload",
    "requiredManifestFields",
    "scopeRequirements",
    "allowedRelations",
    "validationRules",
    "requiredAttestations",
    "riskClass",
    "reviewPolicy",
    "automaticPublicationAllowed",
    "critical"
  ],
  "properties": {
    "profileVersion": { "const": "0.1" },
    "profileId": { "$ref": "common.schema.json#/$defs/uri" },
    "assetType": {
      "enum": [
        "source_document", "assertion", "observation", "procedure", "policy",
        "example", "failure_case", "hypothesis", "dataset", "prompt",
        "capability_manifest"
      ]
    },
    "primaryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mediaTypes"],
      "properties": {
        "mediaTypes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3, "maxLength": 255 }
        },
        "languages": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$" }
        },
        "structuredSchema": { "$ref": "common.schema.json#/$defs/schemaRef" }
      }
    },
    "requiredManifestFields": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^/" }
    },
    "scopeRequirements": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^/scope(?:/|$)" }
    },
    "allowedRelations": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "enum": [
          "supports", "contradicts", "supersedes", "refines", "derived_from",
          "equivalent_to", "applies_under", "invalidates", "evaluates", "used_in"
        ]
      }
    },
    "validationRules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ruleId", "ruleVersion"],
        "properties": {
          "ruleId": {
            "enum": [
              "media-type-allowlist", "utf8-well-formed", "malware-scan",
              "safe-document-parse", "markdown-structure", "source-link-check",
              "policy-completeness", "scope-completeness"
            ]
          },
          "ruleVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
          "parametersDigest": { "$ref": "common.schema.json#/$defs/digest" }
        }
      }
    },
    "requiredAttestations": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "enum": [
          "authorship", "schema-validation", "provenance-validation",
          "human-review", "benchmark-result", "safety-scan",
          "license-review", "policy-approval", "signature-verification"
        ]
      }
    },
    "riskClass": { "enum": ["R0", "R1", "R2", "R3"] },
    "reviewPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumIndependentReviewers", "reviewAfterRequired", "revalidateOn"],
      "properties": {
        "minimumIndependentReviewers": { "type": "integer", "minimum": 0, "maximum": 10 },
        "reviewAfterRequired": { "type": "boolean" },
        "revalidateOn": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "uniqueItems": true,
          "items": {
            "enum": ["profile-change", "policy-change", "source-change", "attestation-expiry"]
          }
        }
      }
    },
    "automaticPublicationAllowed": { "type": "boolean" },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" },
    "critical": { "$ref": "common.schema.json#/$defs/critical" }
  }
}
