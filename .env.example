NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
AKEP_PUBLIC_ORIGIN=http://localhost:3000
AKEP_NODE_ID=https://knowledge.local
AKEP_NODE_NAME=Local Agent Knowledge Node
AKEP_TRUST_DOMAIN=knowledge.local
AKEP_POLICY_EPOCH=bootstrap-1
AKEP_DEFAULT_SPACE=https://knowledge.local/spaces/default
AKEP_TENANT_ID=https://knowledge.local/tenants/local
AUTH_MODE=development
# Production example:
# AUTH_MODE=oidc
# OIDC_ISSUER=https://identity.example.com/
# OIDC_AUDIENCE=https://knowledge.example.com/akep/0.1
# OIDC_JWKS_URI=https://identity.example.com/.well-known/jwks.json
# Comma-separated protected-header typ allowlist; narrow to what the IdP emits.
# OIDC_ACCESS_TOKEN_TYPES=at+jwt
# OIDC_MAX_TOKEN_LIFETIME_SECONDS=3600
TRUST_PROXY=false
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
SLO_P95_MILLISECONDS=800
# Optional OTLP/HTTP collector base endpoint:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=akep-core
DATABASE_URL=postgres://akep:akep-local-only@localhost:5432/akep
# Production always requires a durable migrated database and rejects false.
DATABASE_REQUIRED=false
