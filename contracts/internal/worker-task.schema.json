{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentknowledge.dev/internal/worker-task/0.1",
  "title": "AKEP internal worker task v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "taskId", "kind", "critical"],
  "properties": {
    "contractVersion": { "const": "0.1" },
    "taskId": { "type": "string", "format": "uri", "maxLength": 2048 },
    "kind": { "enum": ["validate_manifest", "process_payload"] },
    "manifest": { "type": "object" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data", "digest", "encoding", "mediaType", "size"],
      "properties": {
        "data": { "type": "string", "maxLength": 13981016 },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "encoding": { "const": "base64" },
        "language": { "type": "string", "minLength": 2, "maxLength": 35 },
        "mediaType": {
          "type": "string",
          "pattern": "^(text/(plain|markdown|html)|application/json)(;[ -~]+)?$",
          "maxLength": 200
        },
        "size": { "type": "integer", "minimum": 0, "maximum": 10485760 }
      }
    },
    "processing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxChunkCharacters": { "type": "integer", "minimum": 256, "maximum": 8000 },
        "overlapCharacters": { "type": "integer", "minimum": 0, "maximum": 512 }
      }
    },
    "claimedRevisionId": {
      "type": "string",
      "pattern": "^urn:akep:sha256:[a-f0-9]{64}$"
    },
    "traceparent": {
      "type": "string",
      "pattern": "^00-[a-f0-9]{32}-[a-f0-9]{16}-[a-f0-9]{2}$"
    },
    "critical": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "format": "uri", "maxLength": 2048 }
    }
  },
  "oneOf": [
    {
      "properties": { "kind": { "const": "validate_manifest" } },
      "required": ["manifest"],
      "not": { "required": ["payload"] }
    },
    {
      "properties": { "kind": { "const": "process_payload" } },
      "required": ["payload"],
      "not": { "required": ["manifest"] }
    }
  ]
}
