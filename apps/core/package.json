{
  "name": "@akep/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "contracts:check": "tsx src/tools/check-contracts.ts",
    "db:migrate": "node --env-file-if-exists=../../.env --import tsx src/tools/migrate.ts",
    "dev": "node --env-file-if-exists=../../.env --watch --import tsx src/server.ts",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "start:container": "node dist/entrypoint.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "fastify": "5.10.0",
    "jose": "^6.2.3",
    "json-canonicalize": "2.0.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
